package assessment_Q_2;

import java.util.Scanner;

public class ProductMain {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		
		int choice=0;
		
		do{
			System.out.println("SELECT THE OPTION BELOW:"
					+ "\n1.ADD ELECTRONIC DETAILS"
					+ "\n2.ADD CLOTHING DETAILS"
					+ "\n3.DISPLAY PRODUT DETAILS");
			
			choice = sc.nextInt();
			
			switch(choice) {
			
			case 1:
				System.out.print("\nPRODUCT_ID:");
				int product_id = sc.nextInt();
				
				System.out.print("PRODUCT_NAME:");
				String product_name = sc.next();
				
				System.out.print("PRICE:");
				double price = sc.nextDouble();
				
				System.out.print("WARRANTY PERIOD:");
				int warranty_period = sc.nextInt();
				
				ElectronicProduct electronic = new ElectronicProduct(product_id,product_name,price,warranty_period);
				
			case 2:
				
				System.out.print("\nPRODUCT_ID:");
				product_id = sc.nextInt();
				
				System.out.print("PRODUCT_NAME:");
				product_name = sc.next();
				
				System.out.print("PRICE:");
				price = sc.nextDouble();
				
				System.out.print("SIZE:");
				String size = sc.next();
				
				System.out.print("MATERIAL:");
				String material = sc.next();
				
				ClothingProduct clothing = new ClothingProduct clothing(product_id,product_name,price,size,material);
			}

			
		}while(choice != 3);

	}

}
